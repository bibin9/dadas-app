generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model User {
  id           String   @id @default(cuid())
  username     String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
}

model Member {
  id        String   @id @default(cuid())
  name      String
  phone     String   @default("")
  active    Boolean  @default(true)
  isGuest   Boolean  @default(false) // guest players for specific matches
  createdAt DateTime @default(now())

  eventDues      EventDue[]
  purchaseSplits PurchaseSplit[]
  payments       Payment[]
  groupLinks     MemberGroupMember[]
  skill          PlayerSkill?
}

model MemberGroup {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())

  members MemberGroupMember[]
}

model MemberGroupMember {
  id       String @id @default(cuid())
  groupId  String
  memberId String

  group  MemberGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  member Member      @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@unique([groupId, memberId])
}

model Event {
  id         String   @id @default(cuid())
  name       String
  type       String   @default("event") // "match" or "event"
  date       DateTime
  perHeadFee Float
  totalCost  Float    @default(0) // actual cost of the event (e.g. ground rent)
  notes      String   @default("")
  createdAt  DateTime @default(now())

  dues     EventDue[]
  payments Payment[]
  incomes  CompanyIncome[]
  expenses EventExpense[]
}

model EventExpense {
  id          String   @id @default(cuid())
  description String                        // e.g. "Venue Rental", "Referee Fee"
  amount      Float
  category    String   @default("venue")    // venue, equipment, referee, transport, food, trophy, medical, other
  date        DateTime
  reference   String   @default("")          // receipt/ref number
  notes       String   @default("")
  eventId     String?                        // optional link to an event
  createdAt   DateTime @default(now())

  event       Event?   @relation(fields: [eventId], references: [id], onDelete: SetNull)
}

model EventDue {
  id       String  @id @default(cuid())
  eventId  String
  memberId String
  amount   Float
  paid     Boolean @default(false)

  event  Event  @relation(fields: [eventId], references: [id], onDelete: Cascade)
  member Member @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@unique([eventId, memberId])
}

model Purchase {
  id          String   @id @default(cuid())
  description String
  totalAmount Float
  date        DateTime
  notes       String   @default("")
  createdAt   DateTime @default(now())

  splits PurchaseSplit[]
}

model PurchaseSplit {
  id         String  @id @default(cuid())
  purchaseId String
  memberId   String
  amount     Float
  paid       Boolean @default(false)

  purchase Purchase @relation(fields: [purchaseId], references: [id], onDelete: Cascade)
  member   Member   @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@unique([purchaseId, memberId])
}

model Payment {
  id        String   @id @default(cuid())
  memberId  String
  amount    Float
  method    String   @default("cash") // cash, bank_transfer, company_contribution
  reference String   @default("") // e.g. transaction ref
  notes     String   @default("")
  date      DateTime
  eventId   String?  // optional link to an event
  category  String   @default("dadas") // "dadas" or "bigticket"
  createdAt DateTime @default(now())

  member Member @relation(fields: [memberId], references: [id], onDelete: Cascade)
  event  Event? @relation(fields: [eventId], references: [id], onDelete: SetNull)
}

model CompanyIncome {
  id          String   @id @default(cuid())
  description String                        // e.g. "Tournament 2025 Sponsorship - XYZ Corp"
  amount      Float
  category    String   @default("sponsorship") // sponsorship, donation, prize, other
  date        DateTime
  reference   String   @default("")          // receipt/ref number
  notes       String   @default("")
  eventId     String?                        // optional link to an event
  createdAt   DateTime @default(now())

  event       Event?   @relation(fields: [eventId], references: [id], onDelete: SetNull)
}

model EventTemplate {
  id          String  @id @default(cuid())
  name        String                        // e.g. "Monthly Big Ticket Purchase"
  type        String  @default("event")     // "match" or "event"
  amount      Float   @default(0)           // default total cost or per-head fee
  amountType  String  @default("total")     // "total" (split equally) or "perhead"
  groupId     String?                       // linked member group
  notes       String  @default("")
  createdAt   DateTime @default(now())
}

model PlayerSkill {
  id         String   @id @default(cuid())
  memberId   String   @unique
  skillTier  String   @default("silver")
  ageGroup   String   @default("senior")
  position   String   @default("any")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @default(now())

  member Member @relation(fields: [memberId], references: [id], onDelete: Cascade)
}

model TeamSheet {
  id        String   @id @default(cuid())
  name      String
  date      DateTime
  teamAName String   @default("Team A")
  teamBName String   @default("Team B")
  teamAIds  String
  teamBIds  String
  notes     String   @default("")
  createdAt DateTime @default(now())
}

model Settings {
  id              String @id @default("main")
  bankName        String @default("")
  accountName     String @default("")
  iban            String @default("")
  accountNumber   String @default("")
  swiftCode       String @default("")
  defaultMatchFee       Float  @default(20)
  defaultBigTicketShare Float   @default(50)
  bigTicketGroupId      String  @default("")  // MemberGroup id for Big Ticket members
  groupName             String  @default("Company")
  autoDeleteDays        Int     @default(0) // 0 = disabled, >0 = auto-delete fully-paid matches after N days
}
